<h2>Blog Posts</h2>

<div class="box">

    {% for post in posts %}
        <a href="https://www.startpage.com/" class="box-item">
            <h3>{{ post.title }}</h3>

            {% if post.tags %}
                <p>{{ post.tags | map(attribute='tag') | join(', ') }}</p>
            {% endif %}

            <p>{{ post.date }}</p>
        </a>
    {% endfor %}
    
</div>